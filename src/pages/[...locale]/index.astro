---
import type { GetStaticPaths } from "astro";
import { registry } from "../../game/registries";
import { gameStrings } from "../../i18n/gameStrings";
import locales from "../../i18n/locales.json";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { unqualify } from "../../minecraft/unqualify";

export const getStaticPaths = (() => {
  return Object.keys(locales.locales).map((id) => ({
    params: { locale: id === locales.default ? undefined : id },
    props: { locale: id },
  }));
}) satisfies GetStaticPaths;

const { locale } = Astro.props;

const blocks = registry("minecraft:block");
const blockStrings = await gameStrings(locale, "block.minecraft");
---

<style>
  .title {
    display: flex;
    justify-content: center;

    padding: var(--u4) 0;

    .image {
      width: calc(40 * var(--u2));
    }
  }
</style>

<BaseLayout {locale}>
  {
    blocks.map((block) => (
      <span>{blockStrings[unqualify(block)] ?? `UNKNOWN ${block}`}</span>
    ))
  }
</BaseLayout>
