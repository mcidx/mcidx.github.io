<style is:global>
  @import "@radix-ui/colors/slate-dark.css";

  :root {
    --base-u: 0.25rem;
    --n: round(down, 100vw / var(--base-u));

    --u0: calc(100vw / var(--n)); /* vanilla-scale art */
    --u1: calc(var(--u0) * 2); /* macro-art */
    --u2: calc(var(--u1) * 2); /* UI */
    --u3: calc(var(--u2) * 2);
    --u4: calc(var(--u3) * 2);
    --u5: calc(var(--u4) * 2);

    --page-width: calc(80 * var(--u2));

    --gray-1: var(--slate-1);
    --gray-2: var(--slate-2);
    --gray-3: var(--slate-3);
    --gray-4: var(--slate-4);
    --gray-5: var(--slate-5);
    --gray-6: var(--slate-6);
    --gray-7: var(--slate-7);
    --gray-8: var(--slate-8);
    --gray-9: var(--slate-9);
    --gray-10: var(--slate-10);
    --gray-11: var(--slate-11);
    --gray-12: var(--slate-12);

    color: var(--gray-12);
  }
</style>
